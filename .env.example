# Tushare Token (Optional for basic realtime quotes)
TUSHARE_TOKEN=your_token

# Common stock codes for batch analyze
COMMON_STOCK_CODES=600519

# ── AI 分析模型配置 ──────────────────────────────────────────
# 当前使用的模型提供商: claude | openai | gemini
AI_PROVIDER=claude

# Claude (Anthropic)
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-opus-4-5
CLAUDE_BASE_URL=

# OpenAI (含兼容接口，如 DeepSeek / 本地 Ollama)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Gemini (Google)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-pro
